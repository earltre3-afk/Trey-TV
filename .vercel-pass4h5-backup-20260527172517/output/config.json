{
  "version": 3,
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?:/((?!api/).*))$",
      "dest": "/index.html",
      "check": true
    },
    {
      "src": "^/api(/.*)?$",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    },
    {
      "handle": "miss"
    },
    {
      "src": "^/api/(.+)(?:\\.(?:ts))$",
      "dest": "/api/$1",
      "check": true
    }
  ],
  "overrides": {},
  "framework": {
    "version": "1.167.35"
  },
  "crons": []
}
