<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction rules. Mirrors backup_rules.xml: exclude the
  Trey TV session prefs from cloud backup AND from device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="treytv_tv_session.xml" />
        <exclude domain="sharedpref" path="treytv_tv_session_fallback.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="treytv_tv_session.xml" />
        <exclude domain="sharedpref" path="treytv_tv_session_fallback.xml" />
    </device-transfer>
</data-extraction-rules>
