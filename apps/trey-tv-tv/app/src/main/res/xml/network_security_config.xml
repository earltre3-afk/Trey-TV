<?xml version="1.0" encoding="utf-8"?>
<!--
  Trey TV TV-app network security config.

  Production posture: HTTPS only. No cleartext fallback. Default trust anchors
  (system CAs) are explicitly opted in.

  Debug-overrides: allow cleartext to LAN IPs and 10.0.2.2 so the dev build
  can talk to a developer's local web server during testing. These overrides
  are stripped from release builds automatically because of the
  cleartextTrafficPermitted=false in <base-config>.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
        <!-- Dev-only cleartext to the Android emulator host loopback and LAN ranges. -->
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="false">10.0.2.2</domain>
            <domain includeSubdomains="false">localhost</domain>
            <domain includeSubdomains="true">192.168.0.0/16</domain>
            <domain includeSubdomains="true">10.0.0.0/8</domain>
        </domain-config>
    </debug-overrides>
</network-security-config>
