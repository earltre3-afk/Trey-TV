# ── Tester access ────────────────────────────────────────────────────────────
# When "true", a build with no existing Supabase session signs in as the
# CaliforniaTrey admin account using the credentials below — a real, data-backed
# session (profile/feed/follows/RLS all work). For tester/QA builds only; leave
# unset/false for normal production. NEVER commit a real password.
VITE_TESTER_ADMIN_AUTOLOGIN=false
VITE_TESTER_ADMIN_EMAIL=californiatrey@gmail.com
VITE_TESTER_ADMIN_PASSWORD=

# ── LiveKit Interactive Story Narration ──────────────────────────────────────
# The URL, API key, and API secret must all come from the same LiveKit Cloud
# project.  If the key/secret pair belongs to a different project, LiveKit
# may reject WebSocket authentication even if the token endpoint returns a
# token.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_AGENT_NAME=Hayden-1f01

# Optional client-side hint (used for display only, not for room.connect).
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_LIVEKIT_AGENT_NAME=Hayden-1f01

# ── Stream Configuration (Trey TV Broadcast) ─────────────────────────────────
STREAM_NAME=Trey TV
STREAM_URL=https://www.tv.treytrizzy.com
STREAM_ID=14912834112
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-QV9ZERGNP4

# ── TMDB Content Scout (server-only — no VITE_ prefix) ───────────────────────
TMDB_API_KEY=your_tmdb_api_key
TMDB_ACCESS_TOKEN=your_tmdb_access_token
